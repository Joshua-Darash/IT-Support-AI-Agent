# Copy this file to .env and fill in your values
# Never commit .env to git

# Your n8n Chat Trigger webhook URL
# Found in: Chat Trigger node → Webhook URL
VITE_N8N_WEBHOOK_URL=https://YOUR-INSTANCE.app.n8n.cloud/webhook/YOUR-WEBHOOK-ID/chat

# Demo login passwords (replace with real auth in production)
VITE_ADMIN_PASS=
VITE_AGENT_PASS=
VITE_DEMO_PASS=demo
